# Discord Query App 环境变量配置
# 复制此文件为 .env 并填入真实值

# Discord Application 信息（从 https://discord.com/developers/applications 获取）
DISCORD_CLIENT_ID=你的Application_ID
DISCORD_CLIENT_SECRET=你的Client_Secret

# 登录回调地址（本地开发用 localhost，部署后改成你的域名）
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback

# 管理员的 Discord 用户 ID（可以上传表格的人）
# 获取方式：在 Discord 开启开发者模式，右键你的头像 → 复制用户 ID
ADMIN_DISCORD_ID=

# Session 加密密钥（留空则每次启动自动生成，但会导致重启后登录失效）
# 建议设一个固定随机字符串
SESSION_SECRET=
